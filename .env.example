# ==============================================================================
# ClarityLoop – Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ==============================================================================

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Your OpenAI API key. Leave empty to use Demo Mode.
OPENAI_API_KEY=

# The OpenAI model name. Must be compatible with the Responses API.
# Examples: gpt-4o, gpt-4o-mini, gpt-4.1, gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini

# Free local AI via Ollama. Install Ollama, run: ollama pull llama3.2:3b,
# then change OLLAMA_ENABLED to true.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=llama3.2:3b

# ── Database ────────────────────────────────────────────────────────────────────
# SQLite (default for local dev). Change to postgresql://... for PostgreSQL.
DATABASE_URL=sqlite:///./clarityloop.db

# ── Features ────────────────────────────────────────────────────────────────────
# Enable web search capability (requires internet access)
ENABLE_WEB_SEARCH=true

# Maximum number of agent review rounds (default: 2)
MAX_AGENT_REVIEW_ROUNDS=2

# Maximum file upload size in megabytes
MAX_UPLOAD_SIZE_MB=20

# ── Demo Mode ───────────────────────────────────────────────────────────────────
# Set to "true" to enable demo mode with seeded data (no API key needed)
DEMO_MODE=false

# ── Frontend ─────────────────────────────────────────────────────────────────────
# Public API URL visible to the browser
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Backend Server ──────────────────────────────────────────────────────────────
# Host and port for the FastAPI backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Security ─────────────────────────────────────────────────────────────────────
# Secret key for signing tokens (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-generate-a-secure-random-key

# ── Logging ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
